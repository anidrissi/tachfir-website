# ============================================================
# TACHFIR — variables d'environnement
# Copiez ce fichier en `.env` et remplissez les valeurs.
# Colonnes conseillées par environnement : voir README.md §Déploiement
# ============================================================

# --- Site ---------------------------------------------------
# URL publique canonique du site (sans slash final). Sert à metadataBase, sitemap, hreflang, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.tachfir.com

# --- Payload CMS ---------------------------------------------
# Secret de chiffrement des sessions/tokens Payload. Générer : `openssl rand -hex 32` (obligatoire, fort, unique par environnement).
PAYLOAD_SECRET=remplacez-par-un-secret-aleatoire-fort

# Connexion base de données. En local/dev : SQLite (fichier). En production : Postgres (Neon ou Vercel Postgres), ex. postgres://user:pass@host/db?sslmode=require
DATABASE_URI=file:./tachfir.db

# Compte administrateur initial créé par `npm run seed` (à changer dès la première connexion !)
PAYLOAD_ADMIN_EMAIL=admin@tachfir.com
PAYLOAD_ADMIN_PASSWORD=ChangezMoi!2026

# --- Médias (production uniquement) --------------------------
# Jeton Vercel Blob (Storage > Blob > créer un store, copier le token). En local, les fichiers vont dans ./media
BLOB_READ_WRITE_TOKEN=

# --- Emails (formulaires devis & contact) --------------------
# Clé API Resend (https://resend.com). Si absente en dev, les emails sont affichés dans la console au lieu d'être envoyés.
RESEND_API_KEY=
# Adresse qui REÇOIT les demandes (devis, bons de commande, contact).
CONTACT_EMAIL=contact@tachfir.com
# Adresse expéditrice (domaine vérifié dans Resend). Par défaut : onboarding@resend.dev (tests uniquement).
EMAIL_FROM=Tachfir <onboarding@resend.dev>

# --- Analytics & Search Console ------------------------------
# ID de mesure Google Analytics 4 (ex. G-XXXXXXXXXX). Vide = GA désactivé.
NEXT_PUBLIC_GA4_ID=
# Jeton de vérification Google Search Console (balise meta). Vide = balise omise.
GOOGLE_SITE_VERIFICATION=
